# Ignore files and directories

# IDE and editor files
.vscode/
.idea/
*.iml
*.suo
*.ntvs*
*.swp
*.swo

# Leptos and Rust files
target/
Cargo.lock
*.rs.bk

# CodeMirror 6 and Highlight.js files
node_modules/
yarn.lock
package-lock.json

# Tauri files
src-tauri/
src-tauri/node_modules/
src-tauri/package-lock.json

# Actix-web and Vercel files
actix-web-*
vercel-build/
vercel-*

# Python and backend files
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyz
*.pyi
.pyenv/
.python-version
env/

# Docker and container files
Dockerfile*
docker-compose*
*.dockerignore

# Log files
logs/
log.txt
error.log
access.log

# OS and system files
.DS_Store
.AppleDouble
.LSOverride
.Trash/
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
[Dd]esktop.ini
$RECYCLE.BIN/
*.tmp
*.bak
*.log
*.lock

# Environment and secrets files
.env
secrets/
credentials.json
credentials.yaml
credentials.toml

# Miscellaneous files
coverage/
node_modules/.cache/
yarn-error.log
npm-debug.log
yarn-debug.log
pnpm-debug.log
pnpm.log
yarn.lock
package-lock.json
.pnp.js
.pnp.cjs
.pnp.mjs
.shims
*.pnp.cjs
*.pnp.mjs
*.pnp.js
*.pnp.json
*.pnp.ts
.prettierrc
.prettierignore
.pnpmfile.cjs
.pnpmfile.js
.pnpmfile.mjs
.pnpmfile.ts
