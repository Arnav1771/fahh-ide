{
  "$schema": "https://schema.tauri.app/config/2/capability.json",
  "identifier": "default",
  "description": "Default capabilities for Fahh Editor — full IDE access",
  "platforms": ["linux", "macOS", "windows"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",

    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",

    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-create-dir",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-remove-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-remove-dir",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "**" }]
    },
    "fs:default",

    "shell:default",
    "shell:allow-open"
  ]
}
