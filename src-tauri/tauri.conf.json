{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.fahh.editor",
  "productName": "Fahh Editor",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "resources": {
      "assets/fahhhh.mp3": "assets/fahhhh.mp3"
    }
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Fahh Editor",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "sidecar": false
    },
    "fs": {
      "scope": {
        "allow": ["**"]
      }
    }
  }
}
