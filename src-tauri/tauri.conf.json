{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.fahh.editor",
  "productName": "Fahh Editor",
  "version": "0.2.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/Square30x30Logo.png",
      "icons/Square44x44Logo.png",
      "icons/Square71x71Logo.png",
      "icons/Square89x89Logo.png",
      "icons/Square107x107Logo.png",
      "icons/Square142x142Logo.png",
      "icons/Square150x150Logo.png",
      "icons/Square284x284Logo.png",
      "icons/Square310x310Logo.png",
      "icons/StoreLogo.png"
    ],
    "resources": {
      "assets/fahhhh.mp3": "assets/fahhhh.mp3"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "tsp": false,
      "wix": {},
      "nsis": {
        "template": null,
        "headerImage": null,
        "sidebarImage": null,
        "installerIcon": null,
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "shortcuts": {
          "desktop": true,
          "startMenu": true
        },
        "allowElevation": true,
        "minimumWebview2Version": "0.1.0"
      }
    }
  },
  "app": {
    "userAgentSuffix": "FahhEditor/0.2.0",
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Fahh Editor",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {}
  }
}
